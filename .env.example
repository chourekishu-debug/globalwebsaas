# ── Copy this file to .env.local and fill in your values ──────

# SUPABASE (get from supabase.com → your project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ANTHROPIC - Claude AI (get free key from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# META ADS (developers.facebook.com/apps)
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
META_AD_ACCOUNT_ID=act_your_ad_account_id

# GOOGLE ADS (ads.google.com → Tools → API Centre)
GOOGLE_ADS_DEVELOPER_TOKEN=your_dev_token
GOOGLE_ADS_CUSTOMER_ID=123-456-7890

# LINKEDIN (linkedin.com/developers)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# WHATSAPP BUSINESS API (Meta Business Suite → WhatsApp)
WHATSAPP_WABA_ID=your_waba_id
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TOKEN=your_system_user_token

# RAZORPAY (dashboard.razorpay.com → Settings → API Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_your_key
RAZORPAY_KEY_SECRET=your_razorpay_secret

# APP
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_SECRET=any_random_32_character_string_here

# ─── Social Publishing (NEW — for auto-posting) ──────────────
# Facebook Page ID (not Ad Account — your Page's numeric ID)
META_PAGE_ID=your_facebook_page_id

# LinkedIn — person ID (urn:li:person:XXXXX) or org ID
LINKEDIN_PERSON_ID=your_linkedin_person_id
LINKEDIN_ORG_ID=your_linkedin_org_id_for_company_page

# Instagram Business User ID (from Meta Business Suite)
INSTAGRAM_USER_ID=your_instagram_business_user_id

# Supabase Storage (for image uploads — optional, uses placeholder if not set)
SUPABASE_STORAGE_BUCKET=social-images

# ─── AI Image Generation ─────────────────────────────────────
# Pollinations.ai: 100% FREE, no key needed, works immediately
# (Platform uses this by default — no setup required)

# Stability AI: 25 free images/day, high quality
# Get key: platform.stability.ai (free account)
STABILITY_API_KEY=your_stability_key_here

# Unsplash: Free stock photos as fallback
# Get key: unsplash.com/developers (free account)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here
